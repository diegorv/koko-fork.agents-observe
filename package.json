{
  "name": "koko-fork-agents-observe",
  "version": "1.0.1",
  "description": "Real-time observability dashboard for Claude Code agents — hardened fork of simple10/agents-observe",
  "license": "MIT",
  "repository": "https://github.com/diegorv/koko-fork-agents-observe",
  "homepage": "https://github.com/diegorv/koko-fork-agents-observe",
  "private": true,
  "scripts": {
    "start": "node start.mjs",
    "test": "npm run test:scripts && cd app/server && npm test && cd ../client && npm test",
    "test:scripts": "vitest run",
    "test:server:watch": "cd app/server && npm run test:watch",
    "test:client:watch": "cd app/client && npm run test:watch",
    "fmt": "npx prettier --write 'app/server/src/**/*.ts' 'app/client/src/**/*.{ts,tsx}' 'hooks/scripts/**/*.mjs' 'test/**/*.mjs' 'start.mjs'",
    "check": "npm test && npm run fmt"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "vitest": "^4.1.6"
  }
}
